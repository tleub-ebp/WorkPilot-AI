{
	"name": "workpilot-ai-ui",
	"version": "1.0.0",
	"type": "module",
	"description": "Desktop UI for WorkPilot AI autonomous coding framework",
	"homepage": "https://github.com/krovomi/WorkPilotAI",
	"repository": {
		"type": "git",
		"url": "https://github.com/krovomi/WorkPilotAI.git"
	},
	"main": "./out/main/index.js",
	"author": {
		"name": "WorkPilot AI Team",
		"email": "krovomi0@users.noreply.github.com"
	},
	"license": "AGPL-3.0",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=8.0.0"
	},
	"scripts": {
		"postinstall": "node -e \"if (!process.env.CI) { var r = require('child_process').spawnSync('electron-rebuild', [], {stdio:'inherit', shell:true}); process.exit(r.status || 0) }\"",
		"dev": "npm run sync-backend-port && electron-vite dev",
		"dev:debug": "cross-env DEBUG=true electron-vite dev",
		"dev:mcp": "electron-vite dev -- --remote-debugging-port=9222",
		"build": "npm run sync-backend-port && electron-vite build",
		"start": "electron .",
		"start:mcp": "electron . --remote-debugging-port=9222",
		"preview": "electron-vite preview",
		"rebuild": "electron-rebuild",
		"python:download": "node scripts/download-python.cjs",
		"python:download:all": "node scripts/download-python.cjs --all",
		"python:verify": "node scripts/verify-python-bundling.cjs",
		"package": "node scripts/package-simple.cjs",
		"package:mac": "node scripts/package-simple.cjs --mac --arm64",
		"package:win": "node scripts/package-simple.cjs --win",
		"package:linux": "node scripts/package-simple.cjs --linux",
		"package:flatpak": "node scripts/package-simple.cjs --linux flatpak",
		"package:python": "node scripts/package-with-python.cjs",
		"package:python:mac": "node scripts/package-with-python.cjs --mac",
		"package:python:win": "node scripts/package-with-python.cjs --win",
		"package:python:linux": "node scripts/package-with-python.cjs --linux",
		"verify:linux": "node scripts/verify-linux-packages.cjs dist",
		"test:verify-linux": "node --test scripts/verify-linux-packages.test.mjs",
		"start:packaged:mac": "open dist/mac-arm64/WorkPilot\\ AI.app || open dist/mac/WorkPilot\\ AI.app",
		"start:packaged:win": "start \"\" \"dist\\win-unpacked\\WorkPilot AI.exe\"",
		"start:packaged:linux": "./dist/linux-unpacked/workpilot-ai",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"fix:electron": "node ../../scripts/fix-electron.js",
		"sync-backend-port": "python ../../scripts/sync_backend_port_to_frontend_env.py"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.71.2",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@lydell/node-pty": "^1.1.0",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-checkbox": "^1.1.4",
		"@radix-ui/react-collapsible": "^1.1.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@sentry/electron": "^7.10.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/react-virtual": "^3.13.13",
		"@types/dompurify": "^3.0.5",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-serialize": "^0.14.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"better-sqlite3": "^12.8.0",
		"chokidar": "^5.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dompurify": "^3.3.2",
		"dotenv": "^17.2.3",
		"electron-log": "^5.4.3",
		"electron-updater": "^6.6.2",
		"file-saver": "^2.0.5",
		"i18next": "^25.7.3",
		"lucide-react": "^1.0.1",
		"minimatch": "^10.2.3",
		"motion": "^12.23.26",
		"proper-lockfile": "^4.1.2",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-i18next": "^16.5.0",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.7.5",
		"reactflow": "^11.10.0",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"semver": "^7.7.3",
		"tailwind-merge": "^3.4.0",
		"uuid": "^13.0.0",
		"xstate": "^5.26.0",
		"zod": "^4.2.1",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/utils": "^4.0.0",
		"@electron/rebuild": "^4.0.2",
		"@playwright/test": "^1.52.0",
		"@tailwindcss/postcss": "^4.1.17",
		"@testing-library/dom": "^10.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/minimatch": "^6.0.0",
		"@types/node": "^25.0.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/semver": "^7.7.1",
		"@types/uuid": "^11.0.0",
		"@vitejs/plugin-react": "^5.1.2",
		"autoprefixer": "^10.4.27",
		"cross-env": "^10.1.0",
		"electron": "41.1.0",
		"electron-builder": "^26.4.0",
		"electron-vite": "5.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.2.7",
		"node-pty": "^1.1.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"unzipper": "^0.10.14",
		"vite": "^7.3.2",
		"vitest": "^4.0.16"
	},
	"overrides": {
		"electron-builder-squirrel-windows": "^26.0.12",
		"dmg-builder": "^26.0.12",
		"@electron/rebuild": "4.0.2"
	},
	"build": {
		"appId": "com.workpilotai.app",
		"productName": "WorkPilot AI",
		"npmRebuild": false,
		"artifactName": "WorkPilot-AI-${version}-${platform}-${arch}.${ext}",
		"publish": [
			{
				"provider": "github",
				"owner": "tleub-ebp",
				"repo": "WorkPilot-AI"
			}
		],
		"directories": {
			"output": "dist",
			"buildResources": "resources"
		},
		"files": [
			"out/**/*",
			"package.json"
		],
		"asarUnpack": [
			"out/main/node_modules/@lydell/node-pty-*/**",
			"out/main/node_modules/node-pty/**",
			"out/main/node_modules/better-sqlite3/**"
		],
		"extraResources": [
			{
				"from": "resources/icon.ico",
				"to": "icon.ico"
			},
			{
				"from": "../backend",
				"to": "backend",
				"filter": [
					"!**/.git",
					"!**/__pycache__",
					"!**/*.pyc",
					"!**/specs",
					"!**/.venv",
					"!**/.venv-*",
					"!**/venv",
					"!**/.env",
					"!**/tests",
					"!**/*.egg-info"
				]
			}
		],
		"mac": {
			"category": "public.app-category.developer-tools",
			"icon": "resources/icon.icns",
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "resources/entitlements.mac.plist",
			"entitlementsInherit": "resources/entitlements.mac.plist",
			"target": [
				"dmg",
				"zip"
			]
		},
		"win": {
			"icon": "resources/icon.ico",
			"target": [
				"nsis",
				"zip",
				"portable"
			]
		},
		"linux": {
			"icon": "resources/icons",
			"target": [
				"AppImage",
				"deb",
				"flatpak",
				"snap"
			],
			"category": "Development"
		},
		"flatpak": {
			"runtime": "org.freedesktop.Platform",
			"runtimeVersion": "25.08",
			"sdk": "org.freedesktop.Sdk",
			"base": "org.electronjs.Electron2.BaseApp",
			"baseVersion": "25.08",
			"finishArgs": [
				"--socket=wayland",
				"--socket=x11",
				"--share=ipc",
				"--share=network",
				"--device=dri",
				"--filesystem=home",
				"--talk-name=org.freedesktop.Notifications"
			]
		}
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
