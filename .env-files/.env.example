# Azure DevOps Connector Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Required Settings
# =============================================================================

# Personal Access Token (PAT) for Azure DevOps authentication.
# Generate at: https://dev.azure.com/{organization}/_usersSettings/tokens
# Required scopes: Code (Read), Work Items (Read)
AZURE_DEVOPS_PAT=your-personal-access-token

# Azure DevOps organization URL.
# Format: https://dev.azure.com/{organization}
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization

# =============================================================================
# GitHub Copilot Optimization Settings
# =============================================================================

# Enable GitHub Copilot token optimization
# Set to 'true' to enable optimization, 'false' to use original Copilot
COPILOT_OPTIMIZATION_ENABLED=false

# Token budget settings for GitHub Copilot components
# COPILOT_TOKEN_BUDGET: Budget for CopilotRuntime (default: 2000)
# COPILOT_CLIENT_BUDGET: Budget for CopilotAgentClient (default: 3000)
# COPILOT_GLOBAL_BUDGET: Global budget across all Copilot components (default: 10000)
COPILOT_TOKEN_BUDGET=2000
COPILOT_CLIENT_BUDGET=3000
COPILOT_GLOBAL_BUDGET=10000

# Optimization level for prompts
# Options: 'minimal', 'standard', 'comprehensive'
# minimal: ~200 tokens, standard: ~600 tokens, comprehensive: ~1200 tokens
COPILOT_PROMPT_LEVEL=standard

# Performance and behavior settings
COPILOT_AUTO_DECOMPOSE=true
COPILOT_CACHE_ENABLED=true
COPILOT_PREDICTIVE_CACHE=true
COPILOT_TOKEN_POOLING=true

# Monitoring and debugging
COPILOT_MONITORING_ENABLED=true
COPILOT_PERFORMANCE_TRACKING=true
COPILOT_OPTIMIZATION_DEBUG=false

# =============================================================================
# Sentry Error Tracking
# =============================================================================

# Sentry DSN for error tracking (backend and frontend)
# Get your DSN from: https://sentry.io/settings/projects/
# Format: https://PUBLIC_KEY@o123.ingest.sentry.io/PROJECT_ID
SENTRY_DSN=your-sentry-dsn

# Optional Sentry settings
#SENTRY_TRACES_SAMPLE_RATE=0.1
#SENTRY_ENVIRONMENT=production
#SENTRY_DEV=false

# =============================================================================
# Optional Settings
# =============================================================================

# Default project name. If set, this project will be used when no project
# is explicitly specified in API calls.
# AZURE_DEVOPS_PROJECT=your-project-name

# =============================================================================
# AI Provider Keys (configure what you use; OAuth is preferred when available)
# =============================================================================

# Anthropic Claude — prefer the OAuth token over the API key when possible.
#ANTHROPIC_API_KEY=sk-ant-...
#CLAUDE_CODE_OAUTH_TOKEN=
#ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (or any OpenAI-compatible endpoint such as z.ai, OpenRouter, ...)
#OPENAI_API_KEY=sk-...
#OPENAI_BASE_URL=https://api.openai.com/v1
#OPENAI_MODEL=gpt-5

# Google Gemini
#GEMINI_API_KEY=
#GOOGLE_MODEL=gemini-2.5-pro

# Grok / xAI
#GROK_API_KEY=
#GROK_MODEL=grok-4

# Mistral / DeepSeek / Meta
#MISTRAL_API_KEY=
#DEEPSEEK_API_KEY=
#META_API_KEY=

# Local Ollama
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen2.5-coder

# =============================================================================
# Issue Tracking Integrations
# =============================================================================

# Linear
#LINEAR_API_KEY=lin_api_...
#LINEAR_TEAM_ID=

# Jira
#JIRA_URL=https://your-org.atlassian.net
#JIRA_EMAIL=you@example.com
#JIRA_API_TOKEN=
#JIRA_PROJECT=

# SonarQube / Figma / Postman
#SONARQUBE_URL=
#SONARQUBE_TOKEN=
#FIGMA_ACCESS_TOKEN=
#POSTMAN_API_KEY=

# =============================================================================
# Memory Layer (Graphiti)
# =============================================================================

# Set to true to enable cross-session graph memory.
#GRAPHITI_ENABLED=false
#GRAPHITI_DATABASE=sqlite
#GRAPHITI_DB_PATH=.workpilot/graphiti.db

# =============================================================================
# Backend Runtime
# =============================================================================

# HTTP port of the FastAPI backend.
#BACKEND_PORT=8765

# Per-user data directory (sessions, profiles, cache).
#WORKPILOT_DATA_DIR=

# Default branch used for new PRs created by WorkPilot.
#DEFAULT_BRANCH=main

# Verbose logging across backend and frontend (also exposes globalThis.DEBUG in renderer).
#DEBUG=false

# See docs/ENV_VARS.md for the exhaustive list and defaults.
